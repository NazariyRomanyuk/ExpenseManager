<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ExpenseManager.UIModels.ViewModels;assembly=ExpenseManager.UIModels"
             xmlns:pages1="clr-namespace:ExpenseManager.Pages"
             x:Class="ExpenseManager.Pages.WalletsPage"             
             x:DataType="pages1:WalletsPage"
             Title="Wallets">
    <CollectionView
        ItemsSource="{Binding Wallets}"
        Margin="10"
        SelectionMode="Single"
        SelectionChanged="WalletSelected">
        <CollectionView.ItemTemplate>
            <DataTemplate
                x:DataType="models:WalletUiViewModel">
                <Border
                    Stroke="Magenta"
                    Padding="5"
                    Margin="0,10">
                    <VerticalStackLayout>
                        <Label 
                            Style="{StaticResource SubHeadline}"
                            Text="{Binding Name}">
                        </Label>
                        <Label
                            HorizontalOptions="Center">
                            <Label.Text>
                                <MultiBinding
                                    StringFormat="{} {0} {1}">
                                    <Binding Path="SumDescription"></Binding>
                                    <Binding Path="Currency" Converter="{StaticResource EnumToDisplayConverter}"></Binding>
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                    </VerticalStackLayout>                    
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>