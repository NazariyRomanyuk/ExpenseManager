<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ExpenseManager.DTOModels.Transaction;assembly=ExpenseManager.DTOModels"
             xmlns:viewModels="clr-namespace:ExpenseManager.ViewModels"
             x:Class="ExpenseManager.Pages.WalletDetailsPage"
             x:DataType="viewModels:WalletDetailsViewModel"
             Title = "Wallet Details" IsEnabled="{Binding IsNotBusy}">
    <ContentPage.Content>
        
        <Grid RowDefinitions="Auto, Auto, Auto, *, Auto">
            <VerticalStackLayout
                Grid.Row="0">
                <BoxView HeightRequest="1" Color="Turquoise" />
                    <VerticalStackLayout Margin="10">
                        <Label 
                            Style="{StaticResource SubHeadline}"
                            Text="{Binding CurrentWallet.Name}">
                        </Label>
                        <Label HorizontalOptions="Center">
                            <MultiBinding
                                StringFormat="{}{0} {1}">
                                <Binding Path="CurrentWallet.OwnerFirstName"></Binding>
                                <Binding Path="CurrentWallet.OwnerLastName"></Binding>
                            </MultiBinding>
                        </Label>
                        <Label
                            HorizontalOptions="Center">
                            <Label.Text>
                                <MultiBinding
                                    StringFormat="{}{0} {1}">
                                    <Binding Path="CurrentWallet.Amount"></Binding>
                                    <Binding Path="CurrentWallet.Currency" Converter="{StaticResource EnumToDisplayConverter}"></Binding>
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                    </VerticalStackLayout>    
                <BoxView HeightRequest="1" Color="Turquoise" />
            </VerticalStackLayout>
            <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="10" Padding="10">
                <Picker
                    Grid.Column="0"
                    Title="Sort by"
                    ItemsSource="{Binding SortOptions}"
                    SelectedItem="{Binding SelectedSort}"/>
                <Picker
                    Grid.Column="1"
                    Title="Filter by Payment Category"
                    ItemDisplayBinding="{Binding Name}"
                    ItemsSource="{Binding CategoryFilters}"
                    SelectedItem="{Binding SelectedCategoryFilter}"/>
            </Grid>
            <SearchBar
                Grid.Row="2"
                Placeholder="Search by description..."
                Text="{Binding DescriptionSearchQuery}"
                Margin="10"></SearchBar>
            <RefreshView
                Command="{Binding RefreshCommand}"
                Grid.Row = "3"
                Margin="10">
                    <CollectionView 
                    ItemsSource="{Binding Transactions}"
                    SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout 
                            Orientation="Vertical" 
                            ItemSpacing="10"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:TransactionListDTO">
                            <Border Stroke="Green" Padding="5" StrokeShape="RoundRectangle 4">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:WalletDetailsViewModel}}, Path=LoadTransactionCommand}"
                                        CommandParameter="{Binding Id}"/>
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="*, Auto">
                                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" HorizontalOptions="Center">
                                        <Label Style="{StaticResource SubHeadline}">
                                            <Label.Text>
                                                <MultiBinding StringFormat="{}{0} {1}">
                                                    <Binding Path="Amount"/>
                                                    <Binding Path="Currency" Converter="{StaticResource EnumToDisplayConverter}"/>
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>
                                        <Label
                                            HorizontalOptions="Center"
                                            Text="{Binding PaymentCategory, Converter={StaticResource EnumToDisplayConverter}}"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="5">
                                        <Button
                                            Text="Edit"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:WalletDetailsViewModel}}, Path=EditTransactionCommand}"
                                            CommandParameter="{Binding .}"/>
                                        <Button
                                            Text="Delete"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:WalletDetailsViewModel}}, Path=DeleteTransactionCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    </CollectionView>
            </RefreshView>
            <Button
                Grid.Row="4"
                Margin="10"
                Command="{Binding AddTransactionCommand }"
                Text="Register New Transaction"
                HorizontalOptions="Center"/>
            <BoxView
                Grid.RowSpan="5"
                IsVisible="{Binding IsBusy}"
                BackgroundColor="DarkGray"
                Opacity="0.1"/>
            <ActivityIndicator
                Grid.RowSpan="5"
                Color="Lime"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                VerticalOptions="Center"
                HorizontalOptions="Center"/>
        </Grid>
    </ContentPage.Content>
</ContentPage>