<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:ExpenseManager.Pages"
             xmlns:models="clr-namespace:ExpenseManager.UIModels.ViewModels;assembly=ExpenseManager.UIModels"
             xmlns:pages1="clr-namespace:ExpenseManager.Pages"
             xmlns:tools="clr-namespace:ExpenseManager.Tools"
             x:Class="ExpenseManager.Pages.WalletsPage"             
             x:DataType="pages1:WalletsPage"
             Title="Wallets">
    <ContentPage.Resources>
        <ResourceDictionary>
            <tools:EnumToDisplayConverter x:Key="EnumToDisplay"></tools:EnumToDisplayConverter>
        </ResourceDictionary>
    </ContentPage.Resources>
    <CollectionView
        ItemsSource="{Binding Wallets}"
        Margin="10"
        SelectionMode="Single">
        <CollectionView.ItemTemplate>
            <DataTemplate
                x:DataType="models:WalletUiViewModel">
                <Border
                    Stroke="Magenta"
                    Padding="5"
                    Margin="0,10">
                    <VerticalStackLayout>
                        <Label HorizontalOptions="Center" Text="{Binding Name}"></Label>
                        <Label HorizontalOptions="Center" Text="{Binding Currency }"></Label>
                        <Label HorizontalOptions="Center" Text="{Binding SumDescription }"></Label>
                    </VerticalStackLayout>                    
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>