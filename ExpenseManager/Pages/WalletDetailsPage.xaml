<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ExpenseManager.DTOModels.Transaction;assembly=ExpenseManager.DTOModels"
             xmlns:viewModels="clr-namespace:ExpenseManager.ViewModels"
             x:Class="ExpenseManager.Pages.WalletDetailsPage"
             x:DataType="viewModels:WalletDetailsViewModel"
             Title = "Wallet Details" IsEnabled="{Binding IsNotBusy}">
    <ContentPage.Content>
        
        <Grid RowDefinitions="Auto, *">
            <VerticalStackLayout>
                <BoxView HeightRequest="1" Color="Turquoise" />
                    <VerticalStackLayout Margin="10">
                        <Label 
                            Style="{StaticResource SubHeadline}"
                            Text="{Binding CurrentWallet.Name}">
                        </Label>
                        <Label HorizontalOptions="Center">
                            <MultiBinding
                                StringFormat="{}{0} {1}">
                                <Binding Path="CurrentWallet.OwnerFirstName"></Binding>
                                <Binding Path="CurrentWallet.OwnerLastName"></Binding>
                            </MultiBinding>
                        </Label>
                        <Label
                            HorizontalOptions="Center">
                            <Label.Text>
                                <MultiBinding
                                    StringFormat="{}{0} {1}">
                                    <Binding Path="CurrentWallet.Amount"></Binding>
                                    <Binding Path="CurrentWallet.Currency" Converter="{StaticResource EnumToDisplayConverter}"></Binding>
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                    </VerticalStackLayout>    
                <BoxView HeightRequest="1" Color="Turquoise" />
            </VerticalStackLayout>
            <CollectionView Grid.Row = "1"
                ItemsSource="{Binding Transactions}"
                Margin="10"
                SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout 
                        Orientation="Vertical" 
                        ItemSpacing="10"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate
                        x:DataType="models:TransactionListDTO">
                        <Border
                            Stroke="Green"
                            Padding="5"
                            StrokeShape="RoundRectangle 4">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding 
                                    Source={RelativeSource AncestorType={x:Type viewModels:WalletDetailsViewModel}},
                                    Path=LoadTransactionCommand}"
                                    CommandParameter="{Binding Id}">
                                </TapGestureRecognizer>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout>
                                <Label 
                                    Style="{StaticResource SubHeadline}">
                                    <Label.Text>
                                        <MultiBinding
                                            StringFormat="{}{0} {1}">
                                            <Binding Path="Amount"></Binding>
                                            <Binding Path="Currency" Converter="{StaticResource EnumToDisplayConverter}"></Binding>
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                                <Label
                                    HorizontalOptions="Center"
                                    Text="{Binding PaymentCategory, Converter={StaticResource EnumToDisplayConverter}}">
                                </Label>
                            </VerticalStackLayout>                    
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <BoxView
                IsVisible="{Binding IsBusy}"
                BackgroundColor="DarkGray"
                Opacity="0.1"/>
            <ActivityIndicator
                Color="Lime"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                VerticalOptions="Center"
                HorizontalOptions="Center"/>
        </Grid>
    </ContentPage.Content>
</ContentPage>